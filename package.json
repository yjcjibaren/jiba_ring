{
  "name": "jibaren-ring-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -b && vite build",
    "build": "npm run build:web",
    "preview": "vite preview",
    "desktop:start": "electron .",
    "build:exe": "npm run build:web && electron-builder --win portable"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "howler": "^2.2.4",
    "phaser": "^3.90.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.codex.jibarenringdemo",
    "productName": "Jibaren Ring",
    "directories": {
      "output": "release/electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "jibaren-ring-demo-portable.exe"
    }
  }
}
